# Copy to .env and fill secrets locally.

# Default live provider: OpenAI.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_EXTRACT=gpt-5.5
OPENAI_MODEL_FAST=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# Optional Yandex AI Studio auth. Used when LLM_PROVIDER=yandex, and still
# supported as an embedding provider if fully configured.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# OpenAI-compatible endpoint from Yandex AI Studio docs.
YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1

# Models are passed as gpt://<folder_id>/<model_name>.
# Keep raw model names here; app.config.settings builds full URIs.
# Model ids must match the Yandex AI Studio catalog; there is no runtime default.
YANDEX_MODEL_EXTRACT=
YANDEX_MODEL_FAST=
YANDEX_EMBEDDING_MODEL=
YANDEX_EMBEDDING_DOCUMENT_MODEL=text-search-doc/latest
YANDEX_EMBEDDING_QUERY_MODEL=text-search-query/latest
YANDEX_REQUEST_TIMEOUT_SECONDS=30
YANDEX_MAX_RETRIES=2

# Feature flags. false = stable demo fixture for /extract, true = live LLM extraction.
SIDECAR_LLM_ENABLED=true
SIDECAR_PORT=8765

# Postgres RAG storage (pgvector). Required for /retrieve and /novelty.
# Embeddings are stored as pgvector `vector` and ranked with cosine `<=>` in SQL.
# compose.yaml provisions pgvector/pgvector:pg16 and sets this automatically.
DATABASE_URL=
