FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY pyproject.toml /app/agent-system/pyproject.toml
WORKDIR /app/agent-system
RUN pip install --upgrade pip && pip install .

COPY . /app/agent-system

EXPOSE 8765

CMD ["uvicorn", "app.api.main:app", "--host", "0.0.0.0", "--port", "8765"]
